{
  "author": "Miguel Zuleta",
  "name": "miguelzuleta.github.io",
  "description": "Miguel Zuleta's Portfolio",
  "version": "2.1.3",
  "scripts": {
    "start": "gulp --watch",
    "prod": "gulp --prod",
    "deploy": "./deploy.sh",
    "test": "babel-node ./node_modules/.bin/jasmine",
    "toDOM": "npx babel ./components/js/helpers/toDOM.js -o ./spec/helpers/toDOM.js",
    "emphasis": "npx babel ./components/js/helpers/emphasis.js -o ./spec/helpers/emphasis.js",
    "testDOM": "npx babel ./spec/helpers/toDOM_test.js -o ./spec/helpers/toDOM_test.built.js",
    "expose": "npm run toDOM & npm run emphasis && npm run testDOM",
    "sp": "npm run expose && browserify ./spec/helpers/emphasis.js ./spec/helpers/toDOM.js ./spec/helpers/toDOM_test.built.js -o ./spec/helpers/expose.built.js && npm test"
  },
  "license": "ISC",
  "devDependencies": {
    "@babel/register": "^7.4.0",
    "babel": "^6.23.0",
    "babel-cli": "^6.26.0",
    "babel-core": "^6.25.0",
    "babel-polyfill": "^6.23.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-register": "^6.24.1",
    "babelify": "^7.3.0",
    "browserify": "^14.4.0",
    "gulp": "^3.9.1",
    "gulp-autoprefixer": "^3.1.1",
    "gulp-concat": "^2.6.0",
    "gulp-connect": "^5.0.0",
    "gulp-eslint": "^4.0.0",
    "gulp-htmlmin": "^3.0.0",
    "gulp-if": "^2.0.1",
    "gulp-jsonmin": "^1.1.0",
    "gulp-rename": "^1.2.2",
    "gulp-sass": "^2.3.2",
    "gulp-scss-lint": "^0.4.0",
    "gulp-sourcemaps": "^2.6.0",
    "gulp-uglify": "^2.0.0",
    "gulp-util": "^3.0.7",
    "jasmine": "^3.3.1",
    "jasmine-node": "^1.16.2",
    "jsdom": "^14.0.0",
    "jshint": "^2.9.3",
    "jshint-stylish": "^2.2.1",
    "node-fetch": "^2.3.0",
    "puppeteer": "^1.14.0",
    "vinyl-buffer": "^1.0.0",
    "vinyl-source-stream": "^1.1.0",
    "watchify": "^3.9.0",
    "yargs": "^8.0.2"
  }
}
